library(quanteda)
library(dplyr)
df <- data.frame(
id = 1:8,
text = c(
"Ich fühle mich heute unglaublich glücklich und voller Selbstsicherheit. Diese kleinen Glücksmomente bedeuten mir viel.",
"Es war ein ganz normaler Tag, nichts Besonderes, aber ich bin trotzdem dankbar für die Echtheit in meinen Beziehungen.",
"Manchmal zweifle ich an mir, aber in seltenen Momenten bin ich wirklich selbstsicher und spüre tiefes Glück.",
"Danke dir! Du hast das wirklich toll gemacht, ich schätze deine Unterstützung sehr und bin ehrlich beeindruckt.",
"Ich bin nicht oft glücklich, aber heute war ein großartiger Tag. So viel Echtheit und Wertschätzung im Team.",
"Es lief nicht alles perfekt, aber ich bin stolz auf mich und dankbar für jede kleine Anerkennung, die ich bekomme.",
"Heute war einfach mühsam und anstrengend, ohne große Höhepunkte oder Glücksmomente.",
"Du bist so unterstützend und wertschätzend, das macht mich richtig glücklich und selbstsicher in dem, was ich tue."
),
stringsAsFactors = FALSE
)
corp <- corpus(df, text_field = "text")
toks <- tokens(
corp,
remove_punct = TRUE,
remove_numbers = TRUE
) |>
tokens_tolower()
pos_dict <- dictionary(list(
pos_emotion = c(
"glück*",       # glücklich, glücksmomente, glücklicher ...
"echte*",       # echt, echte, echtheit ...
"selbstsicher*" # selbstsicher, selbstsicherheit, selbstsicherer ...
),
pos_appreciation = c(
"dank*",        # danke, dankbar, dankbarkeit ...
"toll*",        # toll, tolle, toller ...
"großartig*",   # großartig, großartige ...
"wertschätz*",  # wertschätzung, wertschätzend ...
"anerkenn*",    # anerkennung, anerkennend ...
"stolz*",       # stolz, stolzer ...
"unterstütz*"   # unterstützen, unterstützend, unterstützung ...
)
))
dfm_mat <- dfm(toks)
View(dfm_mat)
pos_counts <- dfm_lookup(
dfm_mat,
dictionary = pos_dict,
valuetype = "glob"    # <--- hier werden * als Wildcards interpretiert
)
pos_counts
View(df)
result <- data.frame(
id = df$id,
total_words = ntoken(toks),
pos_emotion = as.numeric(pos_counts[, "pos_emotion"]),
pos_appreciation = as.numeric(pos_counts[, "pos_appreciation"])
) |>
mutate(
pos_total = pos_emotion + pos_appreciation,
share_pos_emotion = pos_emotion / total_words,
share_pos_appreciation = pos_appreciation / total_words,
share_pos_total = pos_total / total_words
)
print(result)
View(result)
set.seed(123)   # damit die Zufallszahlen reproduzierbar sind
df <- data.frame(
id = 1:8,
text = c(
"Ich fühle mich heute unglaublich glücklich und voller Selbstsicherheit. Diese kleinen Glücksmomente bedeuten mir viel.",
"Es war ein ganz normaler Tag, nichts Besonderes, aber ich bin trotzdem dankbar für die Echtheit in meinen Beziehungen.",
"Manchmal zweifle ich an mir, aber in seltenen Momenten bin ich wirklich selbstsicher und spüre tiefes Glück.",
"Danke dir! Du hast das wirklich toll gemacht, ich schätze deine Unterstützung sehr und bin ehrlich beeindruckt.",
"Ich bin nicht oft glücklich, aber heute war ein großartiger Tag. So viel Echtheit und Wertschätzung im Team.",
"Es lief nicht alles perfekt, aber ich bin stolz auf mich und dankbar für jede kleine Anerkennung, die ich bekomme.",
"Heute war einfach mühsam und anstrengend, ohne große Höhepunkte oder Glücksmomente.",
"Du bist so unterstützend und wertschätzend, das macht mich richtig glücklich und selbstsicher in dem, was ich tue."
),
# Neue Spalte mit zufälligen Self-Esteem-Werten 0–10
selfesteem = sample(0:10, size = 8, replace = TRUE),
stringsAsFactors = FALSE
)
df
corp <- corpus(df, text_field = "text")
toks <- tokens(
corp,
remove_punct = TRUE,
remove_numbers = TRUE
) |>
tokens_tolower()
pos_dict <- dictionary(list(
pos_emotion = c(
"glück*",       # glücklich, glücksmomente, glücklicher ...
"echte*",       # echt, echte, echtheit ...
"selbstsicher*" # selbstsicher, selbstsicherheit, selbstsicherer ...
),
pos_appreciation = c(
"dank*",        # danke, dankbar, dankbarkeit ...
"toll*",        # toll, tolle, toller ...
"großartig*",   # großartig, großartige ...
"wertschätz*",  # wertschätzung, wertschätzend ...
"anerkenn*",    # anerkennung, anerkennend ...
"stolz*",       # stolz, stolzer ...
"unterstütz*"   # unterstützen, unterstützend, unterstützung ...
)
))
dfm_mat <- dfm(toks)
pos_counts <- dfm_lookup(
dfm_mat,
dictionary = pos_dict,
valuetype = "glob"    # <--- hier werden * als Wildcards interpretiert
)
pos_counts
result <- data.frame(
id = df$id,
selfesteem = df$selfesteem,
total_words = ntoken(toks),
pos_emotion = as.numeric(pos_counts[, "pos_emotion"]),
pos_appreciation = as.numeric(pos_counts[, "pos_appreciation"])
) |>
mutate(
pos_total = pos_emotion + pos_appreciation,
share_pos_emotion = pos_emotion / total_words,
share_pos_appreciation = pos_appreciation / total_words,
share_pos_total = pos_total / total_words
)
View(result)
cor.test(result$selfesteem, result$share_pos_emotion)
View(df)
library(mediation)
data(jobs)
####################################################
# Example 1: Linear Outcome and Mediator Models
####################################################
b <- lm(job_seek ~ treat + econ_hard + sex + age, data=jobs)
c <- lm(depress2 ~ treat + job_seek + econ_hard + sex + age, data=jobs)
# Estimation via quasi-Bayesian approximation
contcont <- mediate(b, c, sims=50, treat="treat", mediator="job_seek")
summary(contcont)
summary(contcont)
plot(contcont)
