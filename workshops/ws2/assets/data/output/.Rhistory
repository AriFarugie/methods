id   = ids,
zeit = c("pre", "post")
)
dat$gruppe <- ifelse(dat$id <= n_per_group, "Kontrolle", "Intervention")
# --- Generierung realistischer Werte ---
# Baseline: beide Gruppen gleich
# Intervention verbessert sich von pre → post
dat$score <- with(dat,
30 +                                    # Grundniveau
ifelse(zeit == "post", -2, 0) +         # allgemeiner Lerneffekt
ifelse(gruppe == "Intervention" & zeit == "post", -4, 0) +  # Interventionseffekt
rnorm(nrow(dat), 0, 5)                  # zufällige Variation
)
# --- Faktoren setzen ---
dat$gruppe <- factor(dat$gruppe)
dat$zeit   <- factor(dat$zeit, levels = c("pre", "post"))
dat$id     <- factor(dat$id)
# Ausgabe ansehen
head(dat)
library(afex)
install.packages("afex")
library(afex)
mod <- aov_ez(
id      = "id",
dv      = "score",
data    = dat,
within  = "zeit",
between = "gruppe"
)
mod
nice(mod, es = "pes")
## alternative
mod_aov <- aov(
score ~ gruppe * zeit + Error(id/zeit),
data = dat
)
summary(mod_aov)
library(lme4)
library(lmerTest)   # für p-Werte (Satterthwaite)
library(emmeans)
mod_lmer <- lmer(
score ~ gruppe * zeit + (1 + zeit | id),
data = dat
)
summary(mod_lmer)
mod_lmer <- lmer(
score ~ gruppe * zeit + (1 + zeit | id),
data = dat
)
View(dat)
mod_lmer <- lmer(
score ~ gruppe * zeit + (1 | id),
data = dat
)
summary(mod_lmer)
anova(mod_lmer, type = 3)  # type=3 von lmerTest
library(emmeans)
emm <- emmeans(mod_lmer, ~ gruppe * zeit)
# Gruppenunterschiede zu jedem Zeitpunkt
pairs(emm, by = "zeit", adjust = "bonferroni")
# Veränderung pre → post innerhalb jeder Gruppe
pairs(emm, by = "gruppe", adjust = "bonferroni")
res <- residuals(mod_lmer)
res <- resid(mod_lmer, type = "pearson")
shapiro.test(res)
qqnorm(res)
qqline(res, col = "red", lwd = 2)
library(car)
leveneTest(score ~ gruppe, data = dat)
library(effectsize)
eta_squared(mod_aov, partial = TRUE)
